# Virtual environments
.venv/
venv/
env/

# Python cache / tooling
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.py[cod]
*$py.class

# Environment files
.env
.env.*
!.env.example

# Dados de execução e perfis de automação
data/**/*
data/ai_responses_log*.json
data/google_storage_state*.json
data/gpt_profile/
data/screenshots/
data/debug/

# Local LinkedIn session / secrets
/data/storage_state.json

# Local databases
/data/jobscout.db
*.db
*.sqlite3

# Local raw artifacts and debug evidence
/data/debug/*
!/data/debug/.gitkeep
/data/raw_html/*
!/data/raw_html/.gitkeep

# Local logs generated by automation scripts
/logs/powershell/*
!/logs/powershell/.gitkeep
!/logs/powershell/responses/
/logs/powershell/responses/*
!/logs/powershell/responses/.gitkeep

# Ignorar exportações do banco de dados em Excel
logs/*.xlsx
logs/~$*.xlsx

# Build / packaging
build/
dist/
*.egg-info/

# OS / editor leftovers
.DS_Store
Thumbs.db
.vscode/
.idea/
