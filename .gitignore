# Virtual environments
.venv/
venv/
env/

# Python cache / tooling
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.py[cod]
*$py.class

# Environment files
.env
.env.*
!.env.example

# Local LinkedIn session / secrets
/data/storage_state.json

# Local databases
/data/jobscout.db
*.db
*.sqlite3

# Local raw artifacts and debug evidence
/data/debug/*
!/data/debug/.gitkeep
/data/raw_html/*
!/data/raw_html/.gitkeep

# Local logs generated by automation scripts
/logs/powershell/*
!/logs/powershell/.gitkeep
!/logs/powershell/responses/
/logs/powershell/responses/*
!/logs/powershell/responses/.gitkeep

# Build / packaging
build/
dist/
*.egg-info/

# OS / editor leftovers
.DS_Store
Thumbs.db
.vscode/
.idea/
